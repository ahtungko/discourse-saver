{
  "manifest_version": 3,
  "name": "Discourse Saver",
  "version": "5.5.2",
  "description": "通用Discourse论坛内容保存工具 - 支持全球数百个Discourse站点（LinuxDo、Rust Users、Docker等），悬浮按钮一键保存/长按选楼层，支持Obsidian/飞书/Notion/HTML",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "downloads",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://open.feishu.cn/*",
    "https://open.larksuite.com/*",
    "https://api.notion.com/*",
    "https://www.yuque.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "detector.js"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "Discourse Saver 设置"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}